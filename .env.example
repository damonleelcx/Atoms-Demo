# API keys and secrets for backend (e.g. OpenAI).
# In Kubernetes, create a Secret from this file:
#   kubectl create secret generic atoms-demo-secrets --from-env-file=.env -n atoms-demo
# Or create manually:
#   kubectl create secret generic atoms-demo-secrets --from-literal=OPENAI_API_KEY=sk-your-key -n atoms-demo
# Do not commit .env with real keys. This example is safe to commit.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.1

# Frontend: baked in at Docker build (use empty for same-origin, or e.g. http://localhost:8080 for local dev)
NEXT_PUBLIC_API_URL=
